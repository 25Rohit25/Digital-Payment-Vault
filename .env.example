# Digital Payment Wallet Backend

## Environment Variables (copy to .env)
NODE_ENV=development
PORT=3000

## Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payment_wallet
DB_USER=postgres
DB_PASSWORD=postgres

## Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

## JWT
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

## Email (SMTP - use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@digitalwallet.com

## Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

## Wallet Defaults
DEFAULT_CURRENCY=USD
DEFAULT_DAILY_LIMIT=10000
DEFAULT_MONTHLY_LIMIT=50000
MIN_TRANSACTION_AMOUNT=0.01
MAX_TRANSACTION_AMOUNT=50000
